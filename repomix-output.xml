name: Agent Cassette Diff
description: Compare AI-agent trajectories and publish a deterministic JSON report
inputs:
  baseline:
    description: Baseline cassette path
    required: true
  candidate:
    description: Candidate cassette path
    required: true
  report:
    description: Output JSON report path
    required: false
    default: agent-cassette-report.json
outputs:
  report:
    description: Generated report path
    value: ${{ steps.diff.outputs.report }}
runs:
  using: composite
  steps:
    - name: Install Agent Cassette
      shell: bash
      run: python -m pip install "${GITHUB_ACTION_PATH}"
    - name: Compare trajectories
      id: diff
      shell: bash
      env:
        BASELINE: ${{ inputs.baseline }}
        CANDIDATE: ${{ inputs.candidate }}
        REPORT: ${{ inputs.report }}
      run: |
        echo "report=${REPORT}" >> "${GITHUB_OUTPUT}"
        agent-cassette diff "${BASELINE}" "${CANDIDATE}" --report-json "${REPORT}"
