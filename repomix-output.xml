        {"AGENT_CASSETTE_MODE": "record", "AGENT_CASSETTE_PATH": str(path)}
    ):
        recorded = fake_openai.OpenAI().responses.create(**request)

    with automatic_openai_from_env(
        {"AGENT_CASSETTE_MODE": "replay", "AGENT_CASSETTE_PATH": str(path)}
    ):
